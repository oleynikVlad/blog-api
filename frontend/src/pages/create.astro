---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostForm from '../components/PostForm.astro';
import ErrorMessage from '../components/ErrorMessage.astro';
import { createPost } from '../services/api';

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const title = formData.get('title') as string;
    const content = formData.get('content') as string;

    if (!title || !content) {
      error = 'Title and content are required';
    } else {
      const token = Astro.cookies.get('token')?.value;
      if (!token) {
        return Astro.redirect('/login?redirect=/create');
      }
      const post = await createPost({ title, content }, token);
      return Astro.redirect(`/posts/${post.id}`);
    }
  } catch (e: unknown) {
    const err = e as { message?: string; statusCode?: number };
    if (err.statusCode === 401) {
      return Astro.redirect('/login?redirect=/create');
    }
    error = err.message || 'Failed to create post';
  }
}
---

<BaseLayout title="Create Post">
  <div class="max-w-2xl">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Create New Post</h1>
      <p class="text-gray-500">Share your thoughts with the community.</p>
    </div>

    {error && <div class="mb-6"><ErrorMessage message={error} /></div>}

    <PostForm
      submitLabel="Publish Post"
      action="/create"
    />
  </div>
</BaseLayout>
