---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import ErrorMessage from '../components/ErrorMessage.astro';
import { getPosts } from '../services/api';
import type { Post } from '../types/post';

let posts: Post[] = [];
let error = '';

try {
  posts = await getPosts();
} catch (e: unknown) {
  const err = e as { message?: string };
  error = err.message || 'Failed to load posts';
}
---

<BaseLayout title="Home">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Latest Posts</h1>
    <p class="text-gray-500">Explore the latest articles from our community.</p>
  </div>

  {error ? <ErrorMessage message={error} /> : <PostList posts={posts} />}
</BaseLayout>
