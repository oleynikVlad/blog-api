---
import BaseLayout from '../layouts/BaseLayout.astro';
import ErrorMessage from '../components/ErrorMessage.astro';
import { login, register } from '../services/api';

let error = '';
const redirect = Astro.url.searchParams.get('redirect') || '/';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const action = formData.get('action') as string;

    if (!email || !password) {
      error = 'Email and password are required';
    } else {
      const result =
        action === 'register'
          ? await register(email, password)
          : await login(email, password);

      Astro.cookies.set('token', result.accessToken, {
        path: '/',
        httpOnly: true,
        maxAge: 60 * 60 * 24,
        sameSite: 'lax',
      });

      Astro.cookies.set('user_email', result.user.email, {
        path: '/',
        maxAge: 60 * 60 * 24,
        sameSite: 'lax',
      });

      return Astro.redirect(redirect);
    }
  } catch (e: unknown) {
    const err = e as { message?: string };
    error = err.message || 'Authentication failed';
  }
}
---

<BaseLayout title="Login">
  <div class="max-w-md mx-auto">
    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Welcome</h1>
      <p class="text-gray-500">Login or register to create and manage posts.</p>
    </div>

    {error && <div class="mb-6"><ErrorMessage message={error} /></div>}

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <form method="POST" action={`/login?redirect=${redirect}`} class="space-y-4">
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none transition-colors text-gray-900 placeholder-gray-400"
          />
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
            Password
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength="8"
            placeholder="Minimum 8 characters"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none transition-colors text-gray-900 placeholder-gray-400"
          />
        </div>

        <div class="flex gap-3 pt-2">
          <button
            type="submit"
            name="action"
            value="login"
            class="flex-1 px-4 py-3 bg-sky-600 text-white text-sm font-medium rounded-lg hover:bg-sky-700 focus:ring-2 focus:ring-offset-2 focus:ring-sky-500 transition-colors"
          >
            Login
          </button>
          <button
            type="submit"
            name="action"
            value="register"
            class="flex-1 px-4 py-3 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200 focus:ring-2 focus:ring-offset-2 focus:ring-gray-400 transition-colors"
          >
            Register
          </button>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>
