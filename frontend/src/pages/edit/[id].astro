---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostForm from '../../components/PostForm.astro';
import ErrorMessage from '../../components/ErrorMessage.astro';
import { getPostById, updatePost, deletePost } from '../../services/api';
import type { Post } from '../../types/post';

const { id } = Astro.params;

let post: Post | null = null;
let error = '';

if (!id) {
  error = 'Post ID is required';
}

if (Astro.request.method === 'POST' && id) {
  try {
    const formData = await Astro.request.formData();
    const method = formData.get('_method') as string;
    const token = Astro.cookies.get('token')?.value;

    if (!token) {
      return Astro.redirect(`/login?redirect=/edit/${id}`);
    }

    if (method === 'DELETE') {
      await deletePost(id, token);
      return Astro.redirect('/');
    }

    const title = formData.get('title') as string;
    const content = formData.get('content') as string;

    if (!title && !content) {
      error = 'At least one field must be provided';
    } else {
      const data: Record<string, string> = {};
      if (title) data.title = title;
      if (content) data.content = content;
      await updatePost(id, data, token);
      return Astro.redirect(`/posts/${id}`);
    }
  } catch (e: unknown) {
    const err = e as { message?: string; statusCode?: number };
    if (err.statusCode === 401) {
      return Astro.redirect(`/login?redirect=/edit/${id}`);
    }
    if (err.statusCode === 403) {
      error = 'You can only edit your own posts';
    } else {
      error = err.message || 'Failed to update post';
    }
  }
}

if (id && !error) {
  try {
    post = await getPostById(id);
  } catch (e: unknown) {
    const err = e as { message?: string };
    error = err.message || 'Failed to load post';
  }
}
---

<BaseLayout title={post ? `Edit: ${post.title}` : 'Edit Post'}>
  <div class="max-w-2xl">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Edit Post</h1>
      <p class="text-gray-500">Update your blog post.</p>
    </div>

    {error && <div class="mb-6"><ErrorMessage message={error} /></div>}

    {post && (
      <>
        <PostForm
          title={post.title}
          content={post.content}
          submitLabel="Update Post"
          action={`/edit/${post.id}`}
          method="PATCH"
        />

        <div class="mt-8 pt-6 border-t border-gray-200">
          <h3 class="text-sm font-medium text-gray-700 mb-3">Danger Zone</h3>
          <form method="POST" action={`/edit/${post.id}`}>
            <input type="hidden" name="_method" value="DELETE" />
            <button
              type="submit"
              onclick="return confirm('Are you sure you want to delete this post? This action cannot be undone.')"
              class="inline-flex items-center px-4 py-2 bg-red-50 text-red-600 text-sm font-medium rounded-lg hover:bg-red-100 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
              Delete Post
            </button>
          </form>
        </div>
      </>
    )}
  </div>
</BaseLayout>
