---
import type { Post } from '../types/post';

interface Props {
  post: Post;
}

const { post } = Astro.props;

const preview =
  post.content.length > 180
    ? post.content.substring(0, 180) + '...'
    : post.content;

const date = new Date(post.createdAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
  <a href={`/posts/${post.id}`} class="block group">
    <h2 class="text-xl font-semibold text-gray-900 group-hover:text-sky-600 transition-colors mb-2">
      {post.title}
    </h2>
    <p class="text-gray-600 text-sm leading-relaxed mb-4">{preview}</p>
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        {post.author && (
          <span class="text-xs font-medium text-sky-600 bg-sky-50 px-2 py-1 rounded-full">
            {post.author.email}
          </span>
        )}
      </div>
      <time class="text-xs text-gray-400" datetime={post.createdAt}>
        {date}
      </time>
    </div>
  </a>
</article>
