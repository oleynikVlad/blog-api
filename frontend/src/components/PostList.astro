---
import type { Post } from '../types/post';
import PostCard from './PostCard.astro';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

{posts.length === 0 ? (
  <div class="text-center py-16">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
    </svg>
    <h3 class="text-lg font-medium text-gray-500 mb-1">No posts yet</h3>
    <p class="text-sm text-gray-400">
      Be the first to <a href="/create" class="text-sky-600 hover:underline">create a post</a>.
    </p>
  </div>
) : (
  <div class="grid gap-6">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
)}
