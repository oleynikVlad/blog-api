---
interface Props {
  title?: string;
  content?: string;
  submitLabel: string;
  action: string;
  method?: string;
}

const {
  title = '',
  content = '',
  submitLabel,
  action,
  method = 'POST',
} = Astro.props;
---

<form method="POST" action={action} class="space-y-6">
  <input type="hidden" name="_method" value={method} />

  <div>
    <label for="title" class="block text-sm font-medium text-gray-700 mb-1">
      Title
    </label>
    <input
      type="text"
      id="title"
      name="title"
      value={title}
      required
      maxlength="255"
      placeholder="Enter your post title"
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none transition-colors text-gray-900 placeholder-gray-400"
    />
  </div>

  <div>
    <label for="content" class="block text-sm font-medium text-gray-700 mb-1">
      Content
    </label>
    <textarea
      id="content"
      name="content"
      required
      rows="12"
      placeholder="Write your post content here..."
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none transition-colors text-gray-900 placeholder-gray-400 resize-y"
    >{content}</textarea>
  </div>

  <div class="flex items-center gap-3">
    <button
      type="submit"
      class="inline-flex items-center px-6 py-3 bg-sky-600 text-white text-sm font-medium rounded-lg hover:bg-sky-700 focus:ring-2 focus:ring-offset-2 focus:ring-sky-500 transition-colors"
    >
      {submitLabel}
    </button>
    <a
      href="/"
      class="inline-flex items-center px-6 py-3 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200 transition-colors"
    >
      Cancel
    </a>
  </div>
</form>
