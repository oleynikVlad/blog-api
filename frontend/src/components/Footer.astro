---
const year = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-200 mt-auto">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-sm text-gray-500">
        &copy; {year} Blog. Built with Astro &amp; NestJS.
      </p>
      <div class="flex items-center gap-4">
        <a href="/" class="text-sm text-gray-500 hover:text-gray-700 transition-colors">Home</a>
        <a href="/create" class="text-sm text-gray-500 hover:text-gray-700 transition-colors">New Post</a>
      </div>
    </div>
  </div>
</footer>
